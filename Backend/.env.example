# ── Database ─────────────────────────────────────────────────────
# MongoDB connection string. For local dev you can either:
#   • Use your existing MongoDB Atlas cluster (recommended here), or
#   • Run a local MongoDB (e.g. via Docker) and use:
#       mongodb://127.0.0.1:27017/stencil-oms
# Atlas format (replace <username>/<password>/<cluster>):
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/stencil-oms?retryWrites=true&w=majority

# ── Auth ─────────────────────────────────────────────────────────
# Use a long random string (32+ characters). Keep this secret!
# Generate one at: https://randomkeygen.com
JWT_SECRET=change-this-to-a-long-random-secret-key-minimum-32-chars
JWT_EXPIRES_IN=7d

# ── Server ───────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── CORS / Frontend ──────────────────────────────────────────────
# In one-server local mode the backend serves the frontend itself,
# so this is optional. Add deployed frontend URLs (comma-separated)
# when running them on separate origins.
FRONTEND_URL=http://localhost:5000
